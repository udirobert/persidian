# Contact form email delivery
# If unset, the form falls back to a mailto link + copy-to-clipboard.
RESEND_API_KEY=""
CONTACT_TO_EMAIL="hello@persidian.com"
CONTACT_FROM_EMAIL="Persidian <hello@persidian.com>"

# OpenRouter LLM reasoning for the Business X-ray diagnostic.
# If unset, the diagnostic falls back to deterministic reasoning.
# Note: the tencent/hy3:free slug currently returns reasoning tokens only and no
# final content via OpenRouter, so use the paid tencent/hy3 slug (~$0.00003/call).
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="tencent/hy3"
OPENROUTER_SITE_URL="https://persidian.com"
OPENROUTER_SITE_NAME="Persidian"
